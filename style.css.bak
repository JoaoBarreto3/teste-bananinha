/* ============================================================
   🎨 VARIÁVEIS — EDITE AQUI PARA MUDAR CORES E TIPOGRAFIA
   ============================================================ */
:root {
  /* Cores principais */
  --cor-primaria: #000000;       /* Botões, destaques, hover */
  --cor-primaria-hover: #a80d28;
  --cor-navbar: #945208;         /* Fundo da navbar */
  --cor-footer: #945208;         /* Fundo do footer */
  --cor-fundo: #f5f4ee;          /* Fundo geral da página */
  --cor-fundo-secao: #ffffff;    /* Fundo de seções alternadas */
  --cor-texto: #1a1a1a;          /* Texto principal */
  --cor-texto-suave: #666666;    /* Subtítulos, textos secundários */
  --cor-borda: #e0dfd6;          /* Bordas suaves */

  /* Tipografia */
  --fonte-titulo: 'Georgia', serif;
  --fonte-corpo: 'Helvetica Neue', Arial, sans-serif;

  /* Espaçamento */
  --max-largura: 1100px;
  --raio-borda: 6px;
}

/* ============================================================
   RESET & BASE
   ============================================================ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: var(--fonte-corpo);
  background-color: var(--cor-fundo);
  color: var(--cor-texto);
  line-height: 1.6;
}

img { max-width: 100%; display: block; }
a { color: inherit; }

/* ============================================================
   NAVBAR
   ============================================================ */
.navbar {
  background: var(--cor-navbar);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 2rem;
  height: 90px;
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-logo img {
  height: 70px;
  width: auto;
  display: block;
}

.nav-logo span {
  color: #fff;
  font-size: 1.1rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

.nav-links {
  list-style: none;
  display: flex;
  gap: 0.25rem;
}

.nav-links a {
  color: #fff;
  text-decoration: none;
  font-size: 0.88rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  padding: 0.45rem 0.85rem;
  transition: opacity 0.2s;
}

.nav-links a:hover { opacity: 0.7; }

.nav-cta {
  background: var(--cor-primaria);
  color: #fff !important;
  text-decoration: none;
  font-size: 0.82rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  padding: 0.55rem 1.2rem;
  border-radius: var(--raio-borda);
  transition: background 0.2s;
}

.nav-cta:hover { background: var(--cor-primaria-hover); }

/* ============================================================
   FOOTER
   ============================================================ */
.footer {
  background: var(--cor-footer);
  color: #ccc;
  padding: 3rem 2rem 1.5rem;
}

.footer-inner {
  max-width: var(--max-largura);
  margin: 0 auto;
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  gap: 2.5rem;
}

.footer-brand .footer-logo {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  text-decoration: none;
  margin-bottom: 0.8rem;
}

.footer-brand .footer-logo img {
  height: 36px;
  width: 36px;
  object-fit: contain;
}

.footer-brand .footer-logo span {
  color: #fff;
  font-weight: 700;
  font-size: 1rem;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

.footer-brand p {
  font-size: 0.85rem;
  line-height: 1.7;
  color: #aaa;
}

.footer-col h4 {
  color: #fff;
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 1rem;
}

.footer-col ul {
  list-style: none;
}

.footer-col ul li {
  margin-bottom: 0.5rem;
}

.footer-col ul li a {
  color: #aaa;
  text-decoration: none;
  font-size: 0.88rem;
  transition: color 0.2s;
}

.footer-col ul li a:hover { color: #fff; }

.footer-col p {
  font-size: 0.88rem;
  color: #aaa;
  line-height: 1.8;
}

.footer-bottom {
  max-width: var(--max-largura);
  margin: 2rem auto 0;
  padding-top: 1.2rem;
  border-top: 1px solid rgba(255,255,255,0.08);
  text-align: center;
  font-size: 0.78rem;
  color: #666;
}

/* ============================================================
   HERO (Home)
   ============================================================ */
.hero {
  position: relative;
  min-height: 520px;
  display: flex;
  align-items: center;
  padding: 4rem 2rem;
  overflow: hidden;
}

.hero-inner {
  max-width: var(--max-largura);
  margin: 0 auto;
}

.hero-tag {
  display: inline-block;
  background: var(--cor-primaria);
  color: #fff;
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  padding: 0.3rem 0.8rem;
  border-radius: 2px;
  margin-bottom: 1.2rem;
}

.hero h1 {
  font-family: var(--fonte-titulo);
  font-size: clamp(2rem, 5vw, 3.4rem);
  color: #fff;
  line-height: 1.18;
  max-width: 640px;
  margin-bottom: 1.2rem;
}

.hero p {
  color: rgba(255,255,255,0.82);
  font-size: 1.05rem;
  max-width: 520px;
  margin-bottom: 2rem;
}

.hero-btns {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

.hero-video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.52);
}

.hero-inner {
  position: relative;
  z-index: 2;
}

.btn-primario {
  background: var(--cor-primaria);
  color: #fff;
  text-decoration: none;
  font-weight: 700;
  font-size: 0.88rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  padding: 0.75rem 1.6rem;
  border-radius: var(--raio-borda);
  transition: background 0.2s;
}

.btn-primario:hover { background: var(--cor-primaria-hover); }

.btn-secundario {
  background: transparent;
  color: #fff;
  text-decoration: none;
  font-weight: 700;
  font-size: 0.88rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  padding: 0.75rem 1.6rem;
  border-radius: var(--raio-borda);
  border: 2px solid rgba(255,255,255,0.55);
  transition: border-color 0.2s, color 0.2s;
}

.btn-secundario:hover { border-color: #fff; color: #fff; }

/* ============================================================
   DIFERENCIAIS (Home)
   ============================================================ */
.diferenciais {
  padding: 4rem 2rem;
  background: var(--cor-fundo-secao);
}

.diferenciais-inner {
  max-width: var(--max-largura);
  margin: 0 auto;
}

.secao-titulo {
  text-align: center;
  margin-bottom: 2.8rem;
}

.secao-titulo h2 {
  font-family: var(--fonte-titulo);
  font-size: clamp(1.5rem, 3vw, 2.2rem);
  margin-bottom: 0.5rem;
}

.secao-titulo p {
  color: var(--cor-texto-suave);
  font-size: 0.95rem;
}

.cards-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 1.6rem;
}

.card {
  background: var(--cor-fundo);
  border: 1px solid var(--cor-borda);
  border-radius: var(--raio-borda);
  padding: 1.8rem 1.5rem;
}

.card-icone {
  font-size: 2rem;
  margin-bottom: 1rem;
}

.card h3 {
  font-size: 1rem;
  margin-bottom: 0.5rem;
}

.card p {
  font-size: 0.88rem;
  color: var(--cor-texto-suave);
}

/* ============================================================
   DESTAQUES / CARDÁPIO
   ============================================================ */
.secao-cardapio {
  padding: 4rem 2rem;
  background: var(--cor-fundo);
}

.secao-cardapio-inner {
  max-width: var(--max-largura);
  margin: 0 auto;
}

.cardapio-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
  gap: 1.6rem;
}

.item-cardapio-img {
  height: 190px;
  background-image: var(--img);
  background-position: center;
  background-size: cover;
  background-repeat: no-repeat;
}

.item-cardapio-body {
  padding: 1.2rem;
}

.item-cardapio-body h3 {
  font-size: 1rem;
  margin-bottom: 0.3rem;
}

.item-cardapio-body p {
  font-size: 0.84rem;
  color: var(--cor-texto-suave);
  margin-bottom: 0.8rem;
}

.item-preco {
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--cor-primaria);
}

/* ============================================================
   SOBRE
   ============================================================ */
.sobre-secao {
  padding: 4.5rem 2rem;
}

.sobre-inner {
  max-width: var(--max-largura);
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}

/* 🖼️ IMAGEM DA SEÇÃO SOBRE: mude o src da tag <img> no HTML */
.sobre-img {
  border-radius: var(--raio-borda);
  width: 100%;
  height: 400px;
  object-fit: cover;
  background: #ccc;
}

.sobre-texto h2 {
  font-family: var(--fonte-titulo);
  font-size: clamp(1.6rem, 3vw, 2.2rem);
  margin-bottom: 1rem;
}

.sobre-texto p {
  color: var(--cor-texto-suave);
  font-size: 0.95rem;
  margin-bottom: 1rem;
}

.sobre-numeros {
  display: flex;
  gap: 2rem;
  margin-top: 1.8rem;
  flex-wrap: wrap;
}

.numero-item strong {
  display: block;
  font-size: 2rem;
  font-weight: 800;
  color: var(--cor-primaria);
  line-height: 1;
}

.numero-item span {
  font-size: 0.8rem;
  color: var(--cor-texto-suave);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

/* ============================================================
   CONTATO
   ============================================================ */
.contato-secao {
  padding: 4.5rem 2rem;
  background: var(--cor-fundo-secao);
}

.contato-inner {
  max-width: var(--max-largura);
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr;
  justify-items: center;
}

.contato-info h2 {
  font-family: var(--fonte-titulo);
  font-size: clamp(1.6rem, 3vw, 2.2rem);
  margin-bottom: 1rem;
}

.contato-info p {
  color: var(--cor-texto-suave);
  font-size: 0.95rem;
  margin-bottom: 2rem;
}

.contato-item {
  display: flex;
  align-items: flex-start;
  gap: 0.9rem;
  margin-bottom: 1.3rem;
}

.contato-item-icone {
  font-size: 1.3rem;
  flex-shrink: 0;
  margin-top: 2px;
}

.contato-item-texto strong {
  display: block;
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 0.2rem;
}

.contato-item-texto span,
.contato-item-texto a {
  font-size: 0.92rem;
  color: var(--cor-texto-suave);
  text-decoration: none;
}

.contato-item-texto a:hover { color: var(--cor-primaria); }

/* Formulário */
.form-contato {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.form-contato label {
  font-size: 0.8rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 0.3rem;
  display: block;
}

.form-contato input,
.form-contato textarea,
.form-contato select {
  width: 100%;
  padding: 0.7rem 0.9rem;
  border: 1px solid var(--cor-borda);
  border-radius: var(--raio-borda);
  font-family: var(--fonte-corpo);
  font-size: 0.9rem;
  background: var(--cor-fundo);
  color: var(--cor-texto);
  transition: border-color 0.2s;
}

.form-contato input:focus,
.form-contato textarea:focus,
.form-contato select:focus {
  outline: none;
  border-color: var(--cor-primaria);
}

.form-contato textarea { min-height: 120px; resize: vertical; }

.form-contato .btn-primario {
  border: none;
  cursor: pointer;
  font-family: var(--fonte-corpo);
  width: 100%;
  text-align: center;
}

/* ============================================================
   BANNER CTA (chamada p/ ação no meio da home)
   ============================================================ */
.banner-cta {
  background: var(--cor-primaria);
  padding: 3.5rem 2rem;
  text-align: center;
}

.banner-cta h2 {
  font-family: var(--fonte-titulo);
  font-size: clamp(1.5rem, 3vw, 2rem);
  color: #fff;
  margin-bottom: 0.6rem;
}

.banner-cta p {
  color: rgba(255,255,255,0.85);
  margin-bottom: 1.8rem;
  font-size: 0.95rem;
}

.btn-branco {
  background: #fff;
  color: var(--cor-primaria);
  text-decoration: none;
  font-weight: 700;
  font-size: 0.88rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  padding: 0.75rem 1.8rem;
  border-radius: var(--raio-borda);
  display: inline-block;
  transition: opacity 0.2s;
}

.btn-branco:hover { opacity: 0.88; }

/* ============================================================
   HERO INTERNO (páginas internas)
   ============================================================ */
.hero-interno {
  background: var(--cor-navbar);
  padding: 3rem 2rem;
  text-align: center;
}

.hero-interno h1 {
  font-family: var(--fonte-titulo);
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  color: #fff;
  margin-bottom: 0.5rem;
}

.hero-interno p {
  color: rgba(255,255,255,0.7);
  font-size: 0.95rem;
}

/* ============================================================
   RESPONSIVO
   ============================================================ */
@media (max-width: 768px) {
  .navbar {
    flex-wrap: wrap;
    height: auto;
    padding: 0.75rem 1rem;
    gap: 0.5rem;
  }

  .nav-links {
    order: 3;
    width: 100%;
    flex-direction: column;
    gap: 0;
  }

  .nav-links a {
    display: block;
    padding: 0.6rem 0;
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .nav-cta { order: 2; }

  .footer-inner {
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .sobre-inner,
  .contato-inner {
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .sobre-img { height: 260px; }

  .hero { min-height: 400px; }
}
